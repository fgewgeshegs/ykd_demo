# ============================================
# Claw Assistant Configuration
# ============================================

# Weather API Configuration


# --- WeatherAPI.com (https://www.weatherapi.com) ---
weather.api.url=https://api.weatherapi.com/v1/current.json?key={key}&q={city}&lang=zh
weather.api.key=

# ============================================
# WeChat iLink Configuration
# ============================================
wechat.ilink.enabled=true
wechat.ilink.poll-interval-ms=3000
wechat.ilink.login-poll-interval-ms=3000

# ============================================
# LLM Configuration
# ============================================
llm.api-key=
llm.base-url=https://api.deepseek.com
llm.model=deepseek-v4-flash

# ============================================
# Vision Model Configuration
# ============================================
vision.api-key=
vision.base-url=https://dashscope.aliyuncs.com/compatible-mode/v1
vision.model=qwen-vl-max

# ============================================
# Image Generation Configuration
# ============================================
image.api-key=
image.model=qwen-image-2.0
image.base-url=https://dashscope.aliyuncs.com/api/v1/services/aigc/multimodal-generation/generation

# ============================================
# Voice (ASR + TTS) Configuration
# ============================================
voice.api-key=
voice.asr-base-url=https://dashscope.aliyuncs.com/api/v1/services/audio/transcription/transcription
voice.asr-model=paraformer-v2
voice.tts-base-url=https://{WorkspaceId}.cn-beijing.maas.aliyuncs.com/api/v1/services/audio/tts/SpeechSynthesizer
voice.tts-model=cosyvoice-v2
voice.tts-voice=longxiaochun_v2
voice.tts-enabled=true

# ============================================
# File Parse Configuration
# ============================================
file.parse.max-file-size=10485760
file.parse.max-text-length=30000
file.parse.max-embedded-images=5
file.parse.max-analyzed-embedded-images=3
